FROM node:22-alpine AS development

WORKDIR /app

# Copy package files
COPY package.json yarn.lock ./

# Install all dependencies (including dev dependencies)
RUN yarn install

# Generate Prisma client
COPY prisma/ ./prisma/
RUN npx prisma generate

# Copy source code
COPY . .

# Create logs directory
RUN mkdir -p logs

EXPOSE 3000 9229

CMD ["yarn", "start:dev"]
