generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── Enums ───────────────────────────────────────────────

enum AuthProvider {
  LOCAL
  GOOGLE
  MIXED
}

enum CardStatus {
  NEW
  LEARNING
  REVIEW
  SUSPENDED
}

// ─── Models ──────────────────────────────────────────────

model User {
  id            Int      @id @default(autoincrement())
  name          String   @unique
  email         String   @unique
  passwordHash  String?  @map("password_hash")
  avatarUrl     String?  @map("avatar_url")
  timezone      String?
  emailVerified Boolean  @default(false) @map("email_verified")
  authProvider  AuthProvider @default(LOCAL) @map("auth_provider")
  lastLoginAt   DateTime?   @map("last_login_at")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  oauthAccounts UserOauthAccount[]
  tokens        UserToken[]
  decks         Deck[]
  reviews       Review[]

  @@map("users")
}

model UserOauthAccount {
  id                    Int      @id @default(autoincrement())
  userId                Int      @map("user_id")
  provider              String
  providerUserId        String   @map("provider_user_id")
  providerEmail         String?  @map("provider_email")
  providerName          String?  @map("provider_name")
  providerAvatarUrl     String?  @map("provider_avatar_url")
  providerAccessToken   String?  @map("provider_access_token") @db.Text
  providerRefreshToken  String?  @map("provider_refresh_token") @db.Text
  providerTokenExpiresAt DateTime? @map("provider_token_expires_at")
  rawProfileJson        String?  @map("raw_profile_json") @db.Text
  linkedAt              DateTime @default(now()) @map("linked_at")
  updatedAt             DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_oauth_accounts")
}

model UserToken {
  id         Int      @id @default(autoincrement())
  userId     Int      @map("user_id")
  tokenType  String   @map("token_type")
  tokenHash  String   @map("token_hash") @db.Text
  deviceInfo String?  @map("device_info")
  ipAddress  String?  @map("ip_address")
  isRevoked  Boolean  @default(false) @map("is_revoked")
  issuedAt   DateTime @default(now()) @map("issued_at")
  expiresAt  DateTime @map("expires_at")
  lastUsedAt DateTime? @map("last_used_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_tokens")
}

model Deck {
  id           Int      @id @default(autoincrement())
  userId       Int      @map("user_id")
  name         String
  description  String?  @db.Text
  languageFrom String   @map("language_from")
  languageTo   String   @map("language_to")
  isPublic     Boolean  @default(false) @map("is_public")
  cardCount    Int      @default(0) @map("card_count")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  user  User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  cards Card[]

  @@unique([userId, name])
  @@map("decks")
}

model Card {
  id              Int        @id @default(autoincrement())
  deckId          Int        @map("deck_id")
  word            String
  meaning         String     @db.Text
  exampleSentence String?    @map("example_sentence") @db.Text
  imageUrl        String?    @map("image_url")
  extraNote       String?    @map("extra_note") @db.Text
  ef              Float      @default(2.5)
  repetition      Int        @default(0)
  intervalDays    Int        @default(0) @map("interval_days")
  dueDate         DateTime?  @map("due_date") @db.Date
  lastReviewed    DateTime?  @map("last_reviewed") @db.Date
  status          CardStatus @default(NEW)
  createdAt       DateTime   @default(now()) @map("created_at")
  updatedAt       DateTime   @updatedAt @map("updated_at")

  deck    Deck     @relation(fields: [deckId], references: [id], onDelete: Cascade)
  reviews Review[]

  @@map("cards")
}

model Review {
  id             Int      @id @default(autoincrement())
  cardId         Int      @map("card_id")
  userId         Int      @map("user_id")
  reviewedAt     DateTime @default(now()) @map("reviewed_at")
  quality        Int      // 0-5
  elapsedSeconds Int?     @map("elapsed_seconds")
  oldInterval    Int?     @map("old_interval")
  newInterval    Int?     @map("new_interval")
  oldEf          Float?   @map("old_ef")
  newEf          Float?   @map("new_ef")
  oldRepetition  Int?     @map("old_repetition")
  newRepetition  Int?     @map("new_repetition")

  card Card @relation(fields: [cardId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("reviews")
}
